{
    # Global Seçenekler
    admin off
}

# Ortak Ayarlar Şablonu (Snippets)
(common) {
    encode zstd gzip
    header {
        # Standart Güvenlik Başlıkları
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Server "Caddy" # Server bilgisini gizlemek yerine standartlaştırmak
    }
}

# Frontend - Test
test.epiknovel.com {
    import common
    
    # Medya Dosyaları için Uzun Süreli Önbellekleme (1 Yıl)
    @media {
        path /api/media/* /uploads/*
    }
    header @media Cache-Control "public, max-age=31536000, immutable"

    reverse_proxy epiknovel_web:3000
}

# Legacy Frontend Domain
epiknovel.com, www.epiknovel.com {
    import common

    reverse_proxy epiknovel_web:3000
}

# Backend API
api.epiknovel.com {
    import common
    
    # CORS Ayarları
    header Access-Control-Allow-Origin "https://test.epiknovel.com"
    header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Authorization"
    
    reverse_proxy epiknovel_api:8080
}

# Logs (Seq)
logs.epiknovel.com {
    import common
    # Docker Compose servis ismini (seq) kullanmak daha standarttır
    reverse_proxy seq:80
}

# Spor Kursları - Harici Uygulama
sporkurslari.com, www.sporkurslari.com {
    import common
    # Host üzerindeki 8092 portuna (sporkurslari_app) yönlendirme
    reverse_proxy host.docker.internal:8092
}
